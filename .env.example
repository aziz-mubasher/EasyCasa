# ---------- Domains ----------
# Set to your staging domain for the VPS (Caddy issues TLS automatically).
# Use "localhost" for local development.
# Public brand / hostname (Easy Casa Ita). Compose project name is easycasa-ita.
STAGING_DOMAIN=easycasaita.com

# ---------- Postgres ----------
POSTGRES_USER=easycasa
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=easycasa
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://easycasa:change_me_strong@db:5432/easycasa

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- Meilisearch ----------
MEILI_MASTER_KEY=change_me_meili_key
MEILI_URL=http://meilisearch:7700

# ---------- MinIO (S3-compatible object storage) ----------
MINIO_ROOT_USER=easycasa
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=easycasa-media
S3_ENDPOINT=http://minio:9000

# ---------- App ----------
API_PORT=4000
WEB_PORT=3000
AI_PORT=8000
NODE_ENV=production

# ---------- Backups (restic offsite) ----------
# RESTIC_REPOSITORY=s3:https://s3.example.com/easycasa-backups
# RESTIC_PASSWORD=change_me_restic
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ---------- WordPress source (Phase 1 migration) ----------
WP_DB_HOST=127.0.0.1
WP_DB_PORT=3306
WP_DB_USER=root
WP_DB_PASSWORD=change_me_wp
WP_DB_NAME=wordpress
WP_TABLE_PREFIX=wp_
WP_LISTING_POST_TYPE=listing_type
WP_PERMALINK_BASE=
WP_UPLOADS_BASE_URL=https://easycasaita.com/wp-content/uploads

# ---------- Geocoding ----------
GEOCODER=nominatim
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEOCODER_USER_AGENT=EasyCasaMigration/1.0 (ops@easycasaita.com)

# ---------- Media / CDN ----------
MEDIA_PUBLIC_BASE=https://cdn.easycasaita.com
S3_REGION=us-east-1

# ---------- Auth (Phase 2, OIDC) ----------
# Local/dev on VPS until Keycloak is wired: DEV_AUTH=true + x-dev-* headers.
DEV_AUTH=true
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_ROLES_CLAIM=realm_access.roles

# ---------- Web (Phase 3) ----------
# Server-side fetches use API_URL (internal); browser uses NEXT_PUBLIC_API_URL.
API_URL=http://api:4000
NEXT_PUBLIC_API_URL=https://easycasaita.com/api
NEXT_PUBLIC_OIDC_ISSUER=
NEXT_PUBLIC_OIDC_CLIENT_ID=easycasa-web

# ---------- AI service (Phase 4) ----------
# Embeddings: hashing (offline default) | openai | local
EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# Chat/LLM for the assistant: none (templated fallback) | openai
CHAT_PROVIDER=none
CHAT_MODEL=gpt-4o-mini
USE_LLM_NLQ=false
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
AI_RATE_LIMIT_PER_MIN=30
AI_URL=http://ai:8000
NEXT_PUBLIC_AI_URL=https://easycasaita.com/ai

# ---------- Billing / notifications (Phase 5) ----------
# Leave STRIPE_* empty until keys are set — checkout returns "billing not configured".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_SUCCESS_URL=https://easycasaita.com/it/account?billing=success
BILLING_CANCEL_URL=https://easycasaita.com/it/account?billing=cancel
CURRENCY=eur
SMTP_URL=
NOTIFY_FROM=EasyCasa <no-reply@easycasaita.com>
# Phase 36 EmailModule: SMTP_URL or EMAIL_PROVIDER_URL; neither → fail-soft noop
CORS_ORIGINS=https://easycasaita.com,https://www.easycasaita.com,https://app.easycasaita.com,http://localhost:3000,http://localhost:8081

# ---------- Phase 6 — site / observability ----------
NEXT_PUBLIC_SITE_URL=https://easycasaita.com
ACME_EMAIL=ops@easycasaita.com
# Optional observability overlay (infra/observability/docker-compose.observability.yml)
# GRAFANA_ADMIN_PASSWORD=
# PG_EXPORTER_DSN=postgresql://easycasa:change_me_strong@db:5432/easycasa?sslmode=disable

# ---------- Phase 7 — universal app (see apps/mobile/.env.example) ----------
# EXPO_PUBLIC_API_BASE_URL=https://easycasaita.com/api
# EXPO_PUBLIC_OIDC_ISSUER=https://auth.easycasaita.com/realms/easycasa
# EXPO_PUBLIC_OIDC_CLIENT_ID=easycasa-app
# EXPO_PUBLIC_WEB_APP_URL=https://app.easycasaita.com

# ---------- Phase 10 — e-signature (FEA / SPID-CIE) ----------
SIGNATURE_PROVIDER_URL=
SIGNATURE_PROVIDER_KEY=
SIGNATURE_WEBHOOK_SECRET=

# ---------- Phase 12 — RLI channel + AML screening ----------
# Empty + DEV_AUTH=true → stub protocollo / clean screen (dev only).
RLI_CHANNEL_URL=
RLI_CHANNEL_CREDENTIAL=
AML_SCREENING_URL=
AML_SCREENING_KEY=

# ---------- Phase 17 — order payments + fattura elettronica ----------
# Empty + DEV_AUTH=true → stub PSP client secret / SdI protocollo.
PSP_API_URL=
PSP_SECRET_KEY=
SDI_CHANNEL_URL=
SDI_CHANNEL_KEY=
EASYCASA_PIVA=IT00000000000
EASYCASA_DENOMINAZIONE=Easy Casa Ita Srl

# ---------- Phase 22 / 30 — push / email provider seams ----------
# Empty → console / SMTP_URL fallbacks (fail soft).
PUSH_PROVIDER_URL=
EMAIL_PROVIDER_URL=

# ---------- Phase 38 — GDPR retention ----------
# Unconverted enquiry leads anonymized after N days (default 90).
RETENTION_LEAD_DAYS=90

# ---------- Phase 39 — observability / error tracking ----------
# Empty → fail-soft noop reporter (logs only). Set to enable Sentry.
SENTRY_DSN=
# PUSHGATEWAY_URL=http://pushgateway:9091
# CRITICAL_TABLES=listings enquiries viewings users consent_records

# ---------- Phase 13 — admin console (Vite SPA) ----------
# Bake into admin image; VITE_DEV_AUTH sends x-dev-* headers until OIDC cutover.
VITE_API_BASE_URL=https://easycasaita.com/api
VITE_DEV_AUTH=true
# VITE_OIDC_ISSUER=https://auth.easycasaita.com/realms/easycasa
# VITE_OIDC_CLIENT_ID=easycasa-admin

# ---------- Phase 30 — Keycloak (local: make keycloak; VPS: docker-compose keycloak service) ----------
# KEYCLOAK_HOSTNAME=auth.easycasaita.com
# KEYCLOAK_ADMIN=
# KEYCLOAK_ADMIN_PASSWORD=
# KEYCLOAK_DB=keycloak
