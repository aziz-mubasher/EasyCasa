# ---------- Domains ----------
# Set to your staging domain for the VPS (Caddy issues TLS automatically).
# Use "localhost" for local development.
STAGING_DOMAIN=localhost

# ---------- Postgres ----------
POSTGRES_USER=easycasa
POSTGRES_PASSWORD=change_me_strong
POSTGRES_DB=easycasa
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://easycasa:change_me_strong@db:5432/easycasa

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- Meilisearch ----------
MEILI_MASTER_KEY=change_me_meili_key
MEILI_URL=http://meilisearch:7700

# ---------- MinIO (S3-compatible object storage) ----------
MINIO_ROOT_USER=easycasa
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=easycasa-media
S3_ENDPOINT=http://minio:9000

# ---------- App ----------
API_PORT=4000
WEB_PORT=3000
AI_PORT=8000
NODE_ENV=production

# ---------- Backups (restic offsite) ----------
# RESTIC_REPOSITORY=s3:https://s3.example.com/easycasa-backups
# RESTIC_PASSWORD=change_me_restic
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
