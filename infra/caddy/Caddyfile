# =============================================================================
# EasyCasa — Production Caddyfile (Phase 6)
# Edge: TLS, security headers, compression, rate limiting, 301 redirects,
#        reverse proxy to web (Next.js) and api (NestJS) + ai (FastAPI).
#
# Requires a Caddy build with the rate_limit plugin:
#   xcaddy build \
#     --with github.com/mholt/caddy-ratelimit \
#     --with github.com/caddy-dns/cloudflare        # only if using DNS-01
# The provided infra/caddy/Dockerfile builds this.
#
# Validate:  caddy validate --config infra/caddy/Caddyfile
# =============================================================================
{
	email {$ACME_EMAIL}
	# Cloudflare sits in front for WAF/DDoS; Caddy still terminates TLS on origin.
	servers {
		trusted_proxies static private_ranges {$CLOUDFLARE_IPS}
	}
	# Order the rate_limit handler before reverse_proxy in the pipeline.
	order rate_limit before reverse_proxy
}

# ---- Reusable snippets -------------------------------------------------------

(security_headers) {
	header {
		# HSTS — 2 years, preload. Only enable preload once you're certain.
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(self), camera=(), microphone=(), payment=(self)"
		Cross-Origin-Opener-Policy "same-origin"
		X-XSS-Protection "0"
		# Content-Security-Policy — start in report-only, promote to enforcing
		# after a week of clean reports. Tune script/style hosts to your CDN + Stripe + maps.
		Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://*.tile.openstreetmap.org; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' https://api.stripe.com https://*.easycasa.it; frame-src https://js.stripe.com https://hooks.stripe.com; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; report-uri /csp-report"
		# Strip server fingerprint.
		-Server
	}
}

(compression) {
	encode zstd gzip
}

# Baseline anonymous rate limit: 120 req/min per client IP (burst-friendly window).
(ratelimit_baseline) {
	rate_limit {
		zone baseline {
			key {remote_host}
			events 120
			window 1m
		}
	}
}

# ---- API (api.easycasa.it) ---------------------------------------------------

api.easycasa.it {
	import security_headers
	import compression

	# Tighter limits on the API. Auth + AI endpoints get their own stricter zones.
	rate_limit {
		zone api_auth {
			match {
				path /auth/* /ai/*
			}
			key {remote_host}
			events 20
			window 1m
		}
		zone api_general {
			key {remote_host}
			events 300
			window 1m
		}
	}

	# CORS handled in the app; do not echo arbitrary Origins here.
	reverse_proxy api:3001 {
		health_uri /health
		health_interval 10s
		health_timeout 3s
	}

	log {
		output file /var/log/caddy/api.access.log {
			roll_size 50MiB
			roll_keep 10
		}
		format json
	}
}

# ---- Web (easycasa.it + www) -------------------------------------------------

www.easycasa.it {
	redir https://easycasa.it{uri} permanent
}

easycasa.it {
	import security_headers
	import compression
	import ratelimit_baseline

	# ---- 301 redirect map from the WordPress cutover (Phase 1 output) ----
	# migration/out/redirects.caddy is generated by `pnpm --filter @easycasa/migration redirects`
	# and copied here at deploy time. Keep 301 so link equity transfers.
	import redirects.caddy

	# Long-cache immutable Next.js build assets.
	@nextStatic path /_next/static/*
	header @nextStatic Cache-Control "public, max-age=31536000, immutable"

	# Sitemaps + robots are served by Next route handlers; let them through.
	reverse_proxy web:3000 {
		health_uri /api/health
		health_interval 10s
		health_timeout 3s
	}

	log {
		output file /var/log/caddy/web.access.log {
			roll_size 50MiB
			roll_keep 10
		}
		format json
	}
}
