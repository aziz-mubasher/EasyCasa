{
  "name": "easycasa",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "pnpm --filter @easycasa/shared build && pnpm -r --if-present typecheck",
    "test": "pnpm --filter @easycasa/shared build && pnpm -r --if-present test",
    "build": "pnpm --filter @easycasa/shared build && pnpm -r --if-present build",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  }
}
