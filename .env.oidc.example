# Phase 35 / K EC 1.2 — flip these to cut over from DEV_AUTH to real OIDC.
# Local realm: make keycloak  →  http://localhost:8080/realms/easycasa
# Production: https://auth.easycasaita.com/realms/easycasa

# --- API (required when DEV_AUTH=false) ---
DEV_AUTH=false
OIDC_ISSUER=https://auth.easycasaita.com/realms/easycasa
OIDC_JWKS_URL=https://auth.easycasaita.com/realms/easycasa/protocol/openid-connect/certs
OIDC_AUDIENCE=easycasa-api
OIDC_ROLES_CLAIM=realm_access.roles

# --- Keycloak service (VPS docker-compose keycloak) ---
KEYCLOAK_HOSTNAME=auth.easycasaita.com
KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_DB=keycloak

# --- Web PKCE client (baked into Next.js image at build) ---
NEXT_PUBLIC_OIDC_ISSUER=https://auth.easycasaita.com/realms/easycasa
NEXT_PUBLIC_OIDC_CLIENT_ID=easycasa-web

# --- Expo PKCE client (runtime / EAS build) ---
# EXPO_PUBLIC_OIDC_ISSUER=https://auth.easycasaita.com/realms/easycasa
# EXPO_PUBLIC_OIDC_CLIENT_ID=easycasa-app

# --- Admin SPA PKCE client (baked into admin image at build) ---
# VITE_OIDC_ISSUER=https://auth.easycasaita.com/realms/easycasa
# VITE_OIDC_CLIENT_ID=easycasa-admin
# VITE_DEV_AUTH=false   # flip only after Keycloak is live (see docs/runbooks/oidc-cutover.md)

# --- Local dev overlay (merge instead of production values above) ---
# OIDC_ISSUER=http://localhost:8080/realms/easycasa
# OIDC_JWKS_URL=http://localhost:8080/realms/easycasa/protocol/openid-connect/certs
# NEXT_PUBLIC_OIDC_ISSUER=http://localhost:8080/realms/easycasa
